{
  "manifest_version": 3,
  "name": "Scrimshaw Save",
  "version": "0.1.0",
  "description": "Save the current page to Scrimshaw.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["*://*/*"],
  "action": {
    "default_title": "Save to Scrimshaw",
    "default_popup": "popup.html"
  }
}
