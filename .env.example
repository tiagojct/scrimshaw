# Copy to .env and edit. docker compose reads it automatically.

# Public HTTPS origin behind your reverse proxy. Drives the bookmarklet and iOS
# snippet, and sets the session cookie's Secure flag (off only for an http:// value).
SCRIMSHAW_BASE_URL=https://reader.example.com

# Session cookie signing key: base64url, at least 32 bytes. Leave empty to have
# one generated and persisted under the data directory. Set it explicitly if the
# data directory is ephemeral, so sessions survive a redeploy.
#   generate: openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
SCRIMSHAW_SESSION_SECRET=

# Timeout for every outbound fetch (feeds, saved pages, images, link checks).
SCRIMSHAW_FETCH_TIMEOUT=30s

# Listen address inside the container (the compose file maps 8080 to the host).
# SCRIMSHAW_ADDR=:8080

# Data directory. In the Docker image this is /data (a volume); set it only when
# running the binary directly.
# SCRIMSHAW_DATA_DIR=/data
